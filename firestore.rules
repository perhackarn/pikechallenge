rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Användare – läsbar av sig själv, skrivbar av admin
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
      allow write: if isAdmin();
      // Tillåt att den första admin-användaren skapar sitt eget dokument
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == 'admin';
    }

    // Lag – publikt läsbara (för resultattavlan), skrivbara av admin
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fångster – publikt läsbara, skapbara av inloggade, redigerbara av admin
    match /catches/{catchId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Hjälpfunktion: kolla om användaren är admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
